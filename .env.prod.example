# Copier ce fichier en .env.prod et remplir toutes les valeurs

# --- MySQL ---
MYSQL_ROOT_PASSWORD=ChangezMoi_RootPass!
MYSQL_DATABASE=horizonr_db
MYSQL_USER=horizonr
MYSQL_PASSWORD=ChangezMoi_UserPass!

# --- JWT ---
# Générer avec : openssl rand -hex 64
JWT_SECRET=ChangezMoi_JWTSecret_64CaractèresMinimum
JWT_EXPIRES_IN=8h

# --- CORS ---
# URL publique exacte du frontend (avec port si non-standard)
# Avec NAT 443->4433 : le browser appelle https://horizonr.iris.a3n.fr (port 443 par défaut)
# -> pas de port dans l'URL vue du browser
CORS_ORIGIN=https://horizonr.iris.a3n.fr
