# Copier ce fichier en .env.prod et remplir toutes les valeurs

# --- MySQL ---
MYSQL_ROOT_PASSWORD=ChangezMoi_RootPass!
MYSQL_DATABASE=horizonr_db
MYSQL_USER=horizonr
MYSQL_PASSWORD=ChangezMoi_UserPass!

# --- Backend DB connection (doit correspondre aux valeurs MySQL ci-dessus) ---
DB_NAME=horizonr_db
DB_USER=horizonr
DB_PASSWORD=ChangezMoi_UserPass!

# --- JWT ---
# Générer avec : openssl rand -hex 64
JWT_SECRET=ChangezMoi_JWTSecret_64CaracteresMinimum
JWT_EXPIRES_IN=8h

# --- CORS ---
CORS_ORIGIN=https://horizonr.iris.a3n.fr:4433
